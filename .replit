modules = ["rust-stable"]
[agent]
expertMode = true

[userenv]

[userenv.shared]
APEX_KEYPAIR_PATH = "live-key.json"
APEX_MIN_PROFIT_LAMPORTS = "0"
APEX_MAX_HOPS = "4"
APEX_MAX_POSITION_LAMPORTS = "1000000000"
APEX_JITO_URL = "https://mainnet.block-engine.jito.wtf"
APEX_JITO_TIP_ACCOUNT = "96gYZGLnJYVFmbjzopPSU6QiEV5fGqZNyN9nmNhvrZU5"
APEX_CB_THRESHOLD_LAMPORTS = "5000000000"
APEX_CB_CONSECUTIVE_LOSSES = "10"
APEX_SIMULATION_ONLY = "false"
RUST_LOG = "info"
APEX_ENV = "production"
APEX_FLASH_LOAN_ENABLED = "true"
APEX_AUTO_OPTIMIZE = "true"
APEX_SLIPPAGE_BPS = "50"
APEX_MAX_DAILY_LOSS_LAMPORTS = "500000000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cargo run --bin apex-mev 2>&1"

[workflows.workflow.metadata]
outputType = "console"

[nix]
packages = ["nano"]
